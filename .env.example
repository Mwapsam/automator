# Django
DEBUG=True
DJANGO_SECRET_KEY=change-me-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
# Add your ngrok host here (no scheme) when tunnelling, e.g: 4d42-45-215-236-105.ngrok-free.app
# CSRF_TRUSTED_ORIGINS=https://4d42-45-215-236-105.ngrok-free.app

# PostgreSQL
POSTGRES_DB=automator
POSTGRES_USER=automator
POSTGRES_PASSWORD=automator_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Set to 1 for a local SQLite database (no Postgres/docker needed). Dev only.
USE_SQLITE=0

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Celery
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Feature flags — soft-disable the non-email verticals. Leave False to run the
# email-only product; flip to True to re-enable that vertical's URLs/nav/Celery.
WHATSAPP_ENABLED=False
BITRIX_ENABLED=False

# WhatsApp Cloud API — from Meta Developer App dashboard
# (Per-number system-user/WABA access tokens are stored per number in the
#  dashboard, not here. These are the app-level webhook secrets.)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Embedded Signup — from the onboarding link Meta gives you
# (https://business.facebook.com/messaging/whatsapp/onboard/?app_id=...&config_id=...)
WHATSAPP_APP_ID=
WHATSAPP_CONFIG_ID=
WHATSAPP_GRAPH_VERSION=v21.0

# Email (Stalwart Mail Server)
# Stalwart HTTP Management API — provisions sending domains, DKIM, mailboxes,
# aliases. Port 8080 should be internal-only (not exposed to the internet).
# Generate a dedicated API key in the Stalwart admin UI/CLI (format "API_...");
# do NOT reuse SMTP credentials or the root admin password.
STALWART_API_BASE=http://stalwart:8080
STALWART_API_KEY=
# Provider backend — controls which class handles domain/mailbox provisioning.
# Built-in aliases:
#   stalwart  — Stalwart Mail Server HTTP Management API (production default)
#   null      — no-op stub, succeeds silently (local dev / CI, no real server needed)
# Custom providers: set to a full dotted import path, e.g:
#   MAIL_PROVIDER_BACKEND=myapp.mail.providers.PostfixProvider
MAIL_PROVIDER_BACKEND=stalwart
# Public hostname used to build absolute open/click tracking URLs in outgoing mail.
BASE_DOMAIN=mail.yourhost.com
# SMTP submission credentials (Stalwart port 587) — use a dedicated low-privilege
# Stalwart account here, not the admin account above.
EMAIL_HOST=mail.yourhost.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@yourhost.com

# Bitrix24
# Your portal host (no scheme), e.g. mycompany.bitrix24.com
BITRIX_PORTAL_DOMAIN=
BITRIX_CLIENT_ID=local.123456789
BITRIX_CLIENT_SECRET=xxxxxxxxxxxxxxxx
BITRIX24_OAUTH_REDIRECT_URL=http://localhost:8000/auth/bitrix/callback/

# Flutterwave — uses the v3 API (hosted checkout + subscriptions).
# Get the v3 Secret Key from the CLASSIC dashboard (dashboard.flutterwave.com >
# Settings > API Keys) — it starts with FLWSECK_TEST- (test) or FLWSECK- (live).
# NOT the v4 developer-sandbox "Client Secret" (OAuth) — v4 has no hosted checkout yet.
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxx-X
# Set this to any random string, then paste the same value in FW dashboard > Webhooks > "Secret Hash"
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-secret
FLUTTERWAVE_CURRENCY=USD

# Error monitoring (Sentry) — optional. Leave blank to disable. When set,
# captures unhandled exceptions from the web app and Celery workers.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

# Gunicorn (production web server) — used by docker-compose `web`.
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60